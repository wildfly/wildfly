<module xmlns="urn:jboss:module:1.9" name="org.wildfly.undertow.spi">

    <properties>
        <property name="jboss.api" value="private"/>
    </properties>

    <resources>
        <artifact name="${org.wildfly:wildfly-undertow-spi}"/>
    </resources>

    <dependencies>
        <module name="org.wildfly.service"/>
        <module name="org.wildfly.subsystem"/>

        <!-- Provides host services -->
        <module name="org.wildfly.extension.microprofile.openapi-smallrye" optional="true" services="import"/>
    </dependencies>
</module>
