<subsystem xmlns="urn:wildfly:opentelemetry:community:1.2" system-metrics="true">
    <filters>
        <filter name="accept-app" outcome="accept" field="meter-name" condition="starts-with" value="my_application"/>
        <filter name="reject-jvm" field="meter-name" condition="starts-with" value="jvm"/>
        <filter name="tag-match" field="tag-name" condition="equals" value="someValue"/>
    </filters>
</subsystem>
