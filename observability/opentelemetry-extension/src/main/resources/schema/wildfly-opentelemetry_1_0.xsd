<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="urn:wildfly:opentelemetry:1.0"
           xmlns="urn:wildfly:opentelemetry:1.0"
           elementFormDefault="qualified"
           version="1.0">

    <xs:element name="subsystem">
        <xs:complexType>
            <xs:attribute name="exporter" default="jaeger" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        The name of the exporter to use
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="endpoint" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        The URL for the exporter endpoint.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="span-processor" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        The type of span processor. Acceptable values are 'batch' (default) and 'simple'.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="batch-delay" type="xs:long">
                <xs:annotation>
                    <xs:documentation>
                        The interval, in milliseconds, between two consecutive exports. Default is 5000.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="max-queue-size" type="xs:integer">
                <xs:annotation>
                    <xs:documentation>
                        The maximum size of the queue before it is exported.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="max-export-batch-size" type="xs:integer">
                <xs:annotation>
                    <xs:documentation>
                        The maximum size of the export batch.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="export-timeout" type="xs:long">
                <xs:annotation>
                    <xs:documentation>
                        The maximum allowed time, in milliseconds, to export data.
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="sampler" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        The type of sampler to use
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
            <xs:attribute name="sampler_arg" type="xs:string">
                <xs:annotation>
                    <xs:documentation>
                        The argument to configure the sampler
                    </xs:documentation>
                </xs:annotation>
            </xs:attribute>
        </xs:complexType>
    </xs:element>
</xs:schema>
