    <properties>
        <jbossas.ts.integ.dir>${basedir}/../..</jbossas.ts.integ.dir>
        <jbossas.ts.dir>${jbossas.ts.integ.dir}/..</jbossas.ts.dir>
        <jbossas.project.dir>${jbossas.ts.dir}/..</jbossas.project.dir>

        <!--
             Properties to control when various plugin executions occur that are related to preparing an
             installation to test.

             Profiles can override some of these to enable/disable executions. A value of 'none' disables an execution.
             Other properties are not expected to be overridden, and only exist as properties instead of static values
             so their value is visible here, next to this comment and the overridable properties.

             Note that the following overridable properties inherited from our parent also influence when/if
             relevant executions occur. They default to 'none' and are enabled in profiles.

             ts.microprofile-tck-provisioning.phase
             ts.bootable-jar-packaging.phase

             The following describes the expected sequence of executions related to getting a proper
             installation to test.

             generate-sources
             - wiremock-maven-plugin@run

             compile
             - maven-compiler-plugin@default-testCompile (we run this early to create the target/test-classes dir glow expects.
                                                          See https://github.com/wildfly/wildfly-glow/issues/155)

             process-test-sources
             - (ts.layers, ts.bootable, ts.bootable.preview, ts.preview)  wildfly-glow-arquillian-plugin@scan-deployments

             generate-test-resources
             - produce basic installation
               - (ts.layers and ts.preview) microprofile-tck-provisioning wildfly-maven-plugin@provision
               - OR (ts.bootable and ts.bootable.preview) see process-test-classes
               - OR (other) mp-server-provisioning wildfly-maven-plugin@provision

             process-test-resources
             - install-as-module-wiremock maven-dependency-plugin@copy-dependencies
             - install-wiremock maven-dependency-plugin@copy
             - wiremock-resource-path maven-antrun-plugin@run (exports some properties)
             - echo-wiremock-resource-path maven-antrun-plugin@run (echos those properties)

             test-compile
             - ts.bootable and ts.bootable.preview) write-properties-file-maven-plugin@write-properties-file

             process-test-classes
             - (NOT ts.bootable and ts.bootable.preview)add-wiremock-module wildfly-maven-plugin@execute-commands (module add ....)
             - (ts.bootable and ts.bootable.preview) bootable-jar-packaging wildfly-maven-plugin@package

        -->
        <ts.wiremock-maven-plugin.phase>generate-sources</ts.wiremock-maven-plugin.phase> <!-- NOT overridable -->
        <ts.maven-compiler-plugin.test.phase>compile</ts.maven-compiler-plugin.test.phase>  <!-- NOT overridable -->
        <ts.copy-wildfly.phase>none</ts.copy-wildfly.phase> <!-- overridable -->
        <ts.mp-server-provisioning-phase>generate-test-resources</ts.mp-server-provisioning-phase>  <!-- overridable -->
        <ts.bootable-jar-generate-properties-file.phase>none</ts.bootable-jar-generate-properties-file.phase> <!-- overridable -->
        <ts.install-as-module-wiremock.phase>process-test-resources</ts.install-as-module-wiremock.phase> <!-- NOT overridable -->
        <ts.add-wiremock-module.phase>process-test-classes</ts.add-wiremock-module.phase> <!-- overridable -->

        <ts.microprofile-tck-tests-dependency>org.eclipse.microprofile.rest.client:microprofile-rest-client-tck</ts.microprofile-tck-tests-dependency>

        <!-- Setup properties -->
        <wiremock.lib.path>${project.build.directory}/wiremock</wiremock.lib.path>
        <wiremock.module.included.groupIds>org.wiremock,org.apache.httpcomponents.client5,org.apache.httpcomponents.core5,junit,org.eclipse.jetty</wiremock.module.included.groupIds>
        <wiremock.module.xml.path>${basedir}/module.xml</wiremock.module.xml.path>

        <!-- Wiremock dependency information -->
        <version.wiremock-maven-plugin>7.3.0</version.wiremock-maven-plugin>

        <!-- Expose timeout property to be configurable from CLI because of environment issues -->
        <org.eclipse.microprofile.rest.client.tck.timeoutCushion>90000</org.eclipse.microprofile.rest.client.tck.timeoutCushion>
        <ts.microprofile-tck-glow.expected-discovery>[cdi, ee-integration, jaxrs, jsonb, jsonp, microprofile-config, microprofile-rest-client, servlet]==>ee-core-profile-server,jaxrs,microprofile-rest-client</ts.microprofile-tck-glow.expected-discovery>
    </properties>
